# Required: get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Recommended: raises GitHub rate limit from 60 to 5000 req/hr
# Create at https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

# Claude model to use (default: claude-sonnet-5)
# Other options: claude-opus-4-8, claude-haiku-4-5-20251001
CLAUDE_MODEL=claude-sonnet-5