# Required: get yours at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Recommended: raises GitHub rate limit from 60 to 5000 req/hr
# Create at https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

# Groq model to use (default: llama-3.3-70b-versatile)
# Other options: llama-3.1-8b-instant, mixtral-8x7b-32768, gemma2-9b-it
GROQ_MODEL=llama-3.3-70b-versatile
